{
  "expo": {
    "name": "Hymnals of the Adventist Movement",
    "slug": "hymnals-adventist",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a3a5c"
    },
    "ios": {
      "supportsTablet": true,     
 "bundleIdentifier": "com.therunningpreacher.hymnals",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.adventist.hymnals",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    
      
    
    "extra": {
      "eas": {
        "projectId": "171e33d9-16d6-40ca-84f7-2307bcd6d1af"
      }
    },
    "owner": "therunningpreacher"
  }
}
