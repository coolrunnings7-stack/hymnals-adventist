// Hymnals of the Adventist Movement — v1.0.4
// Changes: audio works in CIS 1908 (recordings are named by CIS number) and in
// the SDA Hymnal via a small cross-reference (SDAH number -> CIS number).
import React, { useState, useMemo, useEffect, useRef } from 'react';
import {
  SafeAreaView, View, Text, TextInput, FlatList, TouchableOpacity,
  StyleSheet, StatusBar, ScrollView,
} from 'react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { Audio } from 'expo-av';
import SDAH_LYRICS from './sdah_lyrics.json';
import CIS_LYRICS from './cis_lyrics.json';
import STORIES from './stories.json';
import { SDAH1985, EDITIONS, sectionFor } from './hymns_data';
import { getAudio } from './audio_manifest';
import cis1908 from './cis1908_hymns.json';
import ch1941 from './ch1941_hymns.json';
import ht1886 from './ht1886_hymns.json';
import mh1854 from './mh1854_hymns.json';
import HT1886_LYRICS from './ht1886_lyrics.json';
import CH1941_LYRICS from './ch1941_lyrics.json';
import FRENCH from './french_lyrics.json';

// Build each hymnal list in the same {n, t} shape as SDAH1985.
const CIS1908 = cis1908.hymns.map(h => ({ n: h.number, t: h.title }));
const CH1941  = ch1941.map(h => ({ n: h.number, t: h.title }));
const HT1886  = ht1886.map(h => ({ n: h.number, t: h.title }));
const MH1854  = mh1854.map(h => ({ n: h.number, t: h.title }));

// Editions we actually have data for. Anything not here shows "being prepared".
const HYMNS = { SDAH1985, CIS1908, CH1941, HT1886, MH1854 };

// NOTE: this SDAH_TO_CIS table is retained for reference only and is no longer
// used for audio. Tunes are now resolved by getAudio() in audio_manifest.js,
// which maps each hymn to a public-domain tune the developer rendered and owns.
