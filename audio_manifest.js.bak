const BY_EDITION = { SDAH1985, CIS1908, CH1941, HT1886 };

export function getAudio(edition, n) {
  const map = BY_EDITION[edition];
  if (!map) return undefined;
  const key = map[n];
  return key ? TUNES[key] : undefined;
}
